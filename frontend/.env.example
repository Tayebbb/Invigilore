# Copy to `.env` or `.env.local` for local development (see https://vitejs.dev/guide/env-and-mode.html)

# API root including /api — must match your Laravel `php artisan serve` / Render URL
VITE_API_BASE_URL=http://127.0.0.1:8000/api

# Backward-compatible alias (optional; api.ts reads VITE_API_BASE_URL first)
# VITE_API_URL=http://127.0.0.1:8000/api

# --- Production (Vercel) — set in Project → Settings → Environment Variables, or use `.env.production` ---
# VITE_API_BASE_URL=https://invigilore.onrender.com/api
