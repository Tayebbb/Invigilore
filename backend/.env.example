APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true

# Laravel URL (used for URL generation, Sanctum, etc.)
# Local: php artisan serve → http://127.0.0.1:8000
APP_URL=http://127.0.0.1:8000

# Optional single frontend origin (merged into CORS in config/cors.php). Leave empty for API-only local testing.
FRONTEND_URL=

# --- Production (Render) — set these in the hosting dashboard, not necessarily in a committed file ---
# APP_ENV=production
# APP_DEBUG=false
# APP_URL=https://invigilore.onrender.com
# FRONTEND_URL=https://invigilore.vercel.app

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# --- Shared Aiven Cloud MySQL ---
# Ask the team lead for the password and ca.pem file
DB_CONNECTION=mysql
DB_HOST=invigilore-learnova.a.aivencloud.com
DB_PORT=21642
DB_DATABASE=defaultdb
DB_USERNAME=avnadmin
DB_PASSWORD=
# Local example (Windows): C:/path/to/your/ca.pem
# Render/Linux example: /var/www/html/ca.pem
MYSQL_ATTR_SSL_CA="/var/www/html/ca.pem"

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
# Production (HTTPS): set SESSION_SECURE_COOKIE=true
SESSION_SECURE_COOKIE=false
SESSION_SAME_SITE=lax

# Comma-separated list of allowed frontend origins (CORS). Add Vercel preview URLs as needed.
FRONTEND_URLS="http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000,http://127.0.0.1:3000,https://invigilore.vercel.app"

# For SPA cookie auth (Sanctum), include frontend hosts without protocol.
SANCTUM_STATEFUL_DOMAINS="localhost,localhost:3000,localhost:5173,127.0.0.1,127.0.0.1:3000,127.0.0.1:5173,invigilore.vercel.app"

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Signup verification emails require a real mailer. Default "log" only writes to storage/logs — no inbox delivery.
# On Render: set MAIL_MAILER=smtp (or resend/postmark) and matching credentials, then redeploy.
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"
# Seconds before SMTP connect/send aborts (avoids long hangs).
MAIL_TIMEOUT=15
# Optional: EHLO domain; should match a domain you control in production.
# MAIL_EHLO_DOMAIN=invigilore.onrender.com

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
