# Docker environment variables
# Copy this file to .env.docker and fill in with your actual values
# This file should NOT be committed to git

# Laravel Configuration
APP_KEY=base64:YOUR_APP_KEY_HERE
APP_URL=http://localhost:8080

# Frontend (CORS / Sanctum) — match your Vite dev server or deployed SPA
FRONTEND_URL=http://localhost:5173
FRONTEND_URLS=http://localhost:5173,http://127.0.0.1:5173,https://invigilore.vercel.app
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:5173,127.0.0.1,127.0.0.1:5173,invigilore.vercel.app

# Database Configuration
DB_CONNECTION=mysql
DB_HOST=your-db-host.com
DB_PORT=3306
DB_DATABASE=your_database
DB_USERNAME=your_username
DB_PASSWORD=your_password

# For Aiven MySQL with SSL:
# MYSQL_ATTR_SSL_CA=/var/www/html/ca.pem

# API Keys
JWT_SECRET=your-jwt-secret-here

# CORS Configuration
SESSION_DOMAIN=localhost
SANCTUM_STATEFUL_DOMAINS=localhost:5173,localhost:8080
